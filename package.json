{
  "name": "mpumpit",
  "private": true,
  "version": "0.3.0",
  "description": "Companion MIDI sound module for midip — plays mpump's AGPL audio engine from any Web MIDI input.",
  "license": "AGPL-3.0-only",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/webmidi": "^2.1.0",
    "@vitejs/plugin-react": "^4.5.1",
    "jsdom": "^25.0.1",
    "typescript": "~5.6.3",
    "vite": "^6.0.0",
    "vitest": "^2.1.8"
  }
}
